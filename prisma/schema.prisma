generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pasta {
  id        String      @id @default(cuid())
  nome      String
  tipo      String      // "looks" ou "designs"
  cor       String      @default("#a855f7")
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  looks     Look[]
  designs   PecaDesign[]
  fotos     FotoPasta[]
}

model FotoPasta {
  id        String   @id @default(cuid())
  pastaId   String
  pasta     Pasta    @relation(fields: [pastaId], references: [id], onDelete: Cascade)
  imageUrl  String   @db.Text
  nome      String?
  createdAt DateTime @default(now())
}

model Look {
  id            String   @id @default(cuid())
  nome          String
  descricao     String
  estilo        String
  ocasiao       String
  genero        String?
  precoEstimado Float
  orcamento     Float
  explicacao    String
  cores         String   // JSON array de hex colors
  outfitJson    String   // JSON completo para avatar 3D
  imageUrl      String?  @db.Text  // foto real do look (base64 jpeg)
  pastaId       String?
  pasta         Pasta?   @relation(fields: [pastaId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pecas         Peca[]
}

model Peca {
  id        String  @id @default(cuid())
  lookId    String
  look      Look    @relation(fields: [lookId], references: [id], onDelete: Cascade)
  categoria String  // "top", "bottom", "shoes", "accessory"
  nome      String
  descricao String
  cor       String
  preco     Float
  tecido    String?
  corte     String?
  detalhes  String?
  lojas     String?  // JSON array de nomes de lojas
}

model PecaDesign {
  id               String   @id @default(cuid())
  nome             String
  tipo             String
  estilo           String
  descricao        String
  tecido           String
  corte            String
  textura          String
  elementosVisuais String
  promptImagem     String
  sugestaoUso      String
  cores            String
  inspiracao       String?
  svgSketch        String?  @db.Text
  pastaId          String?
  pasta            Pasta?   @relation(fields: [pastaId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model User {
  id              String      @id @default(cuid())
  name            String?
  email           String?     @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  accounts        Account[]
  sessions        Session[]
  pastas          Pasta[]
  looks           Look[]
  designs         PecaDesign[]
  avatarProfile   AvatarProfile?
  homeLooks       HomeLook[]
  feedLooks       FeedLook[]
  feedLikes       FeedLike[]
  feedSaves       FeedSave[]
  listings        Listing[]
  messagesSent    MarketMsg[] @relation("MsgFrom")
  messagesReceived MarketMsg[] @relation("MsgTo")
  ordersBuyer     Order[]     @relation("OrderBuyer")
  ordersSeller    Order[]     @relation("OrderSeller")
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

model Listing {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  titulo      String
  descricao   String?
  preco       Float
  categoria   String      // vestuario | calcados | acessorios | bolsas | outros
  tamanho     String?     // PP | P | M | G | GG | único | 34..48 | etc.
  condicao    String      // novo | seminovo | usado
  imageUrls   String      @db.Text  // JSON array of base64
  whatsapp    String?     // ex: "5511999999999"
  status      String      @default("ativo")  // ativo | vendido | pausado
  views       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  messages    MarketMsg[]
  orders      Order[]
}

model MarketMsg {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromUserId  String
  toUserId    String
  fromUser    User     @relation("MsgFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User     @relation("MsgTo",   fields: [toUserId],   references: [id], onDelete: Cascade)
  content     String
  lido        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Order {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  buyerId     String
  sellerId    String
  buyer       User     @relation("OrderBuyer",  fields: [buyerId],  references: [id])
  seller      User     @relation("OrderSeller", fields: [sellerId], references: [id])
  valor       Float
  status      String   @default("pendente")  // pendente | pago | enviado | concluido | cancelado
  pixCode     String?  @db.Text  // copia-e-cola Pix
  pixQrCode   String?  @db.Text  // base64 do QR Code
  mpPaymentId String?  // ID do pagamento no Mercado Pago
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeedLook {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String     @db.Text
  titulo    String
  descricao String?
  tags      String?    // JSON array
  curtidas  FeedLike[]
  salvos    FeedSave[]
  createdAt DateTime   @default(now())
}

model FeedLike {
  feedLookId String
  feedLook   FeedLook @relation(fields: [feedLookId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([feedLookId, userId])
}

model FeedSave {
  feedLookId String
  feedLook   FeedLook @relation(fields: [feedLookId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([feedLookId, userId])
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model AvatarProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  rpmAvatarUrl String?
  skinTone     String?
  hairStyle    String?
  hairColor    String?
  bodyType     String?
  height       String?
  shirtColor   String?
  pantsColor   String?
  shoeColor    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HomeLook {
  id          String   @id @default(cuid())
  userId      String
  nome        String
  descricao   String?
  imageUrl    String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
